{
  "name": "teleport-contest",
  "version": "1.0.0",
  "description": "The Teleport Coding Challenge — Port NetHack C to JavaScript",
  "type": "module",
  "scripts": {
    "score": "bash frozen/score.sh",
    "score:check": "bash frozen/score.sh > /tmp/nh-score.txt && node scripts/check-score.mjs /tmp/nh-score.txt scores/baseline.json",
    "play": "echo 'Open index.html in a browser to play'",
    "prepare": "git config core.hooksPath .githooks",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pages:build": "npm run build --prefix pages"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
